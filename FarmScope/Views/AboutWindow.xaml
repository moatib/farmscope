<Window x:Class="RASLogAggregator.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FarmScope" Height="300" Width="430"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
        FontFamily="{StaticResource UiFont}" FontSize="13">
    <StackPanel Margin="24,20">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
            <TextBlock Text="FarmScope" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource Accent}"/>
            <TextBlock x:Name="VersionText" Text="" FontSize="13"
                       Foreground="{DynamicResource FgDim}" Margin="10,6,0,0"/>
        </StackPanel>
        <TextBlock x:Name="TaglineText" Text="" Foreground="{DynamicResource FgDim}"
                   Margin="0,0,0,16"/>

        <TextBlock x:Name="DevLabel" Text="" Foreground="{DynamicResource FgDim}" FontSize="11.5"/>
        <TextBlock Text="Mathieu PREBIN" FontSize="15" FontWeight="SemiBold" Margin="0,1,0,2"/>
        <TextBlock Margin="0,0,0,16">
            <Hyperlink x:Name="LinkedInLink" NavigateUri="https://www.linkedin.com/in/mathieu-prebin-2a62957a"
                       RequestNavigate="Link_RequestNavigate"
                       Foreground="{DynamicResource Accent}">LinkedIn — mathieu-prebin</Hyperlink>
        </TextBlock>

        <Border BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <TextBlock x:Name="AiText" Text="" TextWrapping="Wrap"
                       Foreground="{DynamicResource FgDim}" FontSize="12"/>
        </Border>

        <Button x:Name="CloseBtn" Content="" Click="Close_Click" Width="90"
                HorizontalAlignment="Right" Margin="0,16,0,0"/>
    </StackPanel>
</Window>
