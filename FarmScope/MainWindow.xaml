<Window x:Class="RASLogAggregator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FarmScope" Height="760" Width="1360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
        FontFamily="{StaticResource UiFont}" FontSize="12.5">

    <DockPanel>
        <!-- Bandeau de marque -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgHeader}" Padding="14,7"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FarmScope" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource Accent}"/>
                    <TextBlock x:Name="SubtitleText" Text="" FontSize="12"
                               Foreground="{DynamicResource FgDim}" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <ComboBox x:Name="LangCombo" Width="58" Margin="0,0,8,0"
                              SelectionChanged="LangCombo_SelectionChanged"
                              Background="{DynamicResource BgPanel}" Foreground="#202020">
                        <ComboBoxItem Content="FR" Tag="fr"/>
                        <ComboBoxItem Content="EN" Tag="en"/>
                        <ComboBoxItem Content="DE" Tag="de"/>
                    </ComboBox>
                    <Button x:Name="ThemeBtn" Content="☀" Width="34" Padding="0,4"
                            Click="ThemeBtn_Click" Margin="0,0,6,0"/>
                    <Button x:Name="AboutBtn" Content="ⓘ" Width="34" Padding="0,4"
                            Click="AboutBtn_Click" Margin="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Barre d'outils -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgHeader}" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ConnectBtn" Content="Connexion / Découverte" Click="Connect_Click"/>
                <Button x:Name="RefreshBtn" Content="↻ Rafraîchir" Click="Refresh_Click" IsEnabled="False"/>
                <CheckBox x:Name="AutoRefreshCheck" Content="Auto" Checked="AutoRefresh_Changed"
                          Unchecked="AutoRefresh_Changed" Margin="6,0,4,0"/>
                <ComboBox x:Name="IntervalCombo" Width="80" SelectedIndex="1" Margin="0,0,16,0"
                          Background="{DynamicResource BgPanel}" Foreground="#202020">
                    <ComboBoxItem Content="10 s" Tag="10"/>
                    <ComboBoxItem Content="30 s" Tag="30"/>
                    <ComboBoxItem Content="60 s" Tag="60"/>
                </ComboBox>

                <Label x:Name="SearchLabel" Content="Recherche :"/>
                <TextBox x:Name="SearchBox" Width="260" Padding="6,3" Margin="0,0,4,0"
                         TextChanged="Filter_Changed"
                         Background="{DynamicResource BgPanel}" Foreground="{DynamicResource Fg}"
                         BorderBrush="{DynamicResource Line}" CaretBrush="{DynamicResource Accent}"/>

                <Button x:Name="ExportBtn" Content="Exporter CSV" Click="Export_Click" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Filtres : pills de sévérité (filtre + compteur) et combos -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgPanel}" Padding="12,7">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="ChkError" Content="Error" IsChecked="True" Click="Filter_Changed"
                          Style="{StaticResource SeverityChip}"
                          Foreground="{DynamicResource Error}" Tag="{DynamicResource ErrorFill}"/>
                <CheckBox x:Name="ChkWarn" Content="Warn" IsChecked="True" Click="Filter_Changed"
                          Style="{StaticResource SeverityChip}"
                          Foreground="{DynamicResource Warn}" Tag="{DynamicResource WarnFill}"/>
                <CheckBox x:Name="ChkInfo" Content="Info" IsChecked="True" Click="Filter_Changed"
                          Style="{StaticResource SeverityChip}"
                          Foreground="{DynamicResource Fg}" Tag="{DynamicResource InfoFill}"/>
                <CheckBox x:Name="ChkDebug" Content="Debug" IsChecked="False" Click="Filter_Changed"
                          Style="{StaticResource SeverityChip}"
                          Foreground="{DynamicResource Debug}" Tag="{DynamicResource DebugFill}"/>
                <CheckBox x:Name="ChkOther" Content="Autre" IsChecked="True" Click="Filter_Changed"
                          Style="{StaticResource SeverityChip}"
                          Foreground="{DynamicResource FgDim}" Tag="{DynamicResource OtherFill}"/>

                <Separator Margin="14,0" Background="{DynamicResource Line}"/>

                <TextBlock x:Name="RoleLabel" Text="Rôle :" Foreground="{DynamicResource FgDim}" Margin="0,0,6,0"/>
                <ComboBox x:Name="RoleFilter" Width="150" SelectionChanged="Filter_Changed" Margin="0,0,14,0"
                          Background="{DynamicResource BgPanel}" Foreground="#202020"/>

                <TextBlock x:Name="ServerLabel" Text="Serveur :" Foreground="{DynamicResource FgDim}" Margin="0,0,6,0"/>
                <ComboBox x:Name="ServerFilter" Width="190" SelectionChanged="Filter_Changed" Margin="0,0,14,0"
                          Background="{DynamicResource BgPanel}" Foreground="#202020"/>

                <TextBlock x:Name="FileLabel" Text="Fichier :" Foreground="{DynamicResource FgDim}" Margin="0,0,6,0"/>
                <ComboBox x:Name="FileFilter" Width="170" SelectionChanged="Filter_Changed"
                          Background="{DynamicResource BgPanel}" Foreground="#202020"/>
            </StackPanel>
        </Border>

        <!-- Barre d'état -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgHeader}" Padding="12,5"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="" Foreground="{DynamicResource FgDim}"/>
                <TextBlock x:Name="CountText" Text="" Foreground="{DynamicResource FgDim}"
                           FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Zone centrale : grille + détail -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="170" MinHeight="60"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="LogGrid" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionChanged="LogGrid_SelectionChanged"
                      Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                      RowBackground="{DynamicResource RowBg}"
                      AlternatingRowBackground="{DynamicResource RowAltBg}"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource GridLine}"
                      BorderBrush="{DynamicResource Line}" BorderThickness="0"
                      HeadersVisibility="Column"
                      EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      FontFamily="{StaticResource MonoFont}" FontSize="12">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource BgHeader}"/>
                        <Setter Property="Foreground" Value="{DynamicResource FgDim}"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11.5"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Severity}" Value="ERROR">
                                <Setter Property="Foreground" Value="{DynamicResource Error}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="WARN">
                                <Setter Property="Foreground" Value="{DynamicResource Warn}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="DEBUG">
                                <Setter Property="Foreground" Value="{DynamicResource Debug}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="TRACE">
                                <Setter Property="Foreground" Value="{DynamicResource Debug}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <!-- Rail de sévérité : signature visuelle de FarmScope -->
                    <DataGridTemplateColumn Width="10" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Rectangle Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Severity}" Value="ERROR">
                                                    <Setter Property="Fill" Value="{DynamicResource Error}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="WARN">
                                                    <Setter Property="Fill" Value="{DynamicResource Warn}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="DEBUG">
                                                    <Setter Property="Fill" Value="{DynamicResource Debug}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="TRACE">
                                                    <Setter Property="Fill" Value="{DynamicResource Debug}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="ColTime" Header="Horodatage" Binding="{Binding TimeDisplay}"
                                        Width="180" SortMemberPath="Timestamp"/>
                    <DataGridTextColumn x:Name="ColSev" Header="Sév." Binding="{Binding Severity}" Width="60"/>
                    <DataGridTextColumn x:Name="ColRole" Header="Rôle" Binding="{Binding Role}" Width="120"/>
                    <DataGridTextColumn x:Name="ColServer" Header="Serveur" Binding="{Binding Server}" Width="200"/>
                    <DataGridTextColumn x:Name="ColFile" Header="Fichier" Binding="{Binding LogFile}" Width="140"/>
                    <DataGridTextColumn x:Name="ColMsg" Header="Message" Binding="{Binding MessagePreview}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Line}"/>

            <Border Grid.Row="2" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Line}"
                    BorderThickness="0,1,0,0">
                <TextBox x:Name="DetailBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" BorderThickness="0"
                         Background="{DynamicResource BgPanel}" Foreground="{DynamicResource Fg}"
                         FontFamily="{StaticResource MonoFont}" FontSize="12.5" Padding="10"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
